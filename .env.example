# Database — direct upstream connection. Used by Prisma migrate / db push
# and as the runtime fallback when DATABASE_URL_POOLED is unset.
DATABASE_URL=postgresql://nexaflow:nexaflow@localhost:5432/nexaflow_dev

# Pooled connection via PgBouncer. Set this in prod (and when running
# multi-replica). When unset, runtime falls back to DATABASE_URL.
# Append `?pgbouncer=true` so Prisma disables prepared statements
# (required for transaction-mode pooling).
# DATABASE_URL_POOLED=postgresql://nexaflow:nexaflow@localhost:6432/nexaflow_dev?pgbouncer=true

# Read replica (T-101). When set, read-heavy paths (conversation list,
# analytics, audit logs) route through this URL via the `prismaRead`
# client. Writes always go to DATABASE_URL_POOLED || DATABASE_URL.
# When unset, prismaRead aliases to the primary client (no-op).
# DATABASE_URL_READ=postgresql://nexaflow:nexaflow@replica-host:5432/nexaflow_dev

# Redis (single-node)
REDIS_URL=redis://localhost:6379

# Redis Cluster — comma-separated list of seed nodes. When set, getRedis()
# returns a cluster client and REDIS_URL is ignored at the app layer.
# Hash tags in keys (e.g. `send:{tenantId}:sec`) keep all keys for one
# tenant on the same slot, so multi-key ops stay safe.
# REDIS_CLUSTER_URLS=redis://10.0.0.1:6379,redis://10.0.0.2:6379,redis://10.0.0.3:6379

# Per-account login throttle (T-091) — defaults match the SECURITY.md target.
# LOGIN_FAILS_MAX=5
# LOGIN_FAILS_WINDOW_SECONDS=900

# Auth context cache TTL (T-090) — controls how fast suspensions take effect.
# AUTH_CTX_CACHE_TTL_SECONDS=60

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# WhatsApp & Meta
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_PHONE_NUMBER_ID=your_phone_number_id
META_BUSINESS_ACCOUNT_ID=your_waba_id
WHATSAPP_WEBHOOK_TOKEN=your_webhook_verification_token

# Meta Embedded Signup (T-004). Web reads NEXT_PUBLIC_* for the FB SDK
# to open the popup; API reads META_APP_ID + META_APP_SECRET to exchange
# the code. Without these the manual /whatsapp-settings form still works.
# NEXT_PUBLIC_META_APP_ID=
# NEXT_PUBLIC_META_EMBEDDED_SIGNUP_CONFIG_ID=

# WABA token expiry warn worker (ADR-022). Defaults: warn ≤14 days out,
# re-warn cooldown 24h, scan every 6h.
# WABA_TOKEN_EXPIRY_WARN_DAYS=14
# WABA_TOKEN_EXPIRY_WARN_COOLDOWN_HOURS=24
# WABA_TOKEN_EXPIRY_SCAN_INTERVAL_MS=21600000

# Gupshup BSP (T-005c). Only consulted when a tenant has a ProviderRoute
# row with providerKey=GUPSHUP. Per-tenant config from ProviderRoute.config
# lands in a follow-up; env-only is the bootstrap path.
# GUPSHUP_API_BASE_URL=https://api.gupshup.io/wa/api/v1
# GUPSHUP_API_KEY=your_gupshup_api_key
# GUPSHUP_APP_NAME=your_gupshup_app_id
# GUPSHUP_SOURCE=15551234567

# AI / LLM APIs
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key
OPENAI_ORG_ID=your_org_id

# AWS/S3
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
S3_BUCKET_NAME=nexaflow-media

# Payment Gateways
RAZORPAY_KEY_ID=your_razorpay_key
RAZORPAY_KEY_SECRET=your_razorpay_secret
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# Email
EMAIL_PROVIDER=resend
RESEND_API_KEY=your_resend_api_key
SENDGRID_API_KEY=your_sendgrid_api_key
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email
SMTP_PASSWORD=your_password
SMTP_FROM=noreply@nexaflow.ai

# Authentication
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
NEXTAUTH_SECRET=your_nextauth_secret
NEXTAUTH_URL=http://localhost:3000

# Application
NODE_ENV=development
APP_MODE=all
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000
# Public browser/API base used by the Next.js client bundle. Docker builds
# can override this with `NEXT_PUBLIC_API_URL=https://api.example.com`.
NEXT_PUBLIC_API_URL=http://localhost:3001
LOG_LEVEL=debug
API_RATE_LIMIT_MAX=300
PUBLIC_BOOKING_RATE_LIMIT_MAX=20

# Monitoring (T-121 Sentry, T-122 Prometheus)
SENTRY_DSN=your_sentry_dsn
SENTRY_ENVIRONMENT=development
# SENTRY_RELEASE=  # set to the deploy SHA in CI
SENTRY_TRACES_SAMPLE_RATE=0.1
DATADOG_API_KEY=your_datadog_api_key

# Feature Flags
ENABLE_AI_CREATIVE_STUDIO=true
ENABLE_ADS_INTEGRATION=true
ENABLE_CHATBOT_BUILDER=true

# Tenant secret encryption (T-094) — KEK for envelope-encrypting
# Tenant.wabaAccessToken and similar secrets at rest. Required in
# production. In dev a deterministic fallback is used.
TENANT_TOKEN_ENCRYPTION_KEY=dev_tenant_encryption_master_key_change_in_prod

# Wallet billing (T-001)
# When false (default), wallet pre-checks + debits are no-ops; the ledger
# stays decorative. Flip to true once tenants have funded wallets.
WALLET_BILLING_ENABLED=false
WHATSAPP_MESSAGE_COST_CREDITS=1
AI_CALL_COST_CREDITS=1
# Optional per-feature AI override. Feature names are uppercased and non-alphanumeric
# characters become underscores, e.g. feature `campaign_autopilot`:
AI_CALL_COST_CREDITS_CAMPAIGN_AUTOPILOT=2
