{
  "name": "@nexaflow/api",
  "version": "0.1.0",
  "description": "NexaFlow AI - Node.js/Express Backend API",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "DOTENV_CONFIG_PATH=../../.env tsx watch src/index.ts",
    "dev:api": "DOTENV_CONFIG_PATH=../../.env APP_MODE=api tsx watch src/index.ts",
    "dev:worker": "DOTENV_CONFIG_PATH=../../.env APP_MODE=worker tsx watch src/index.ts",
    "build": "tsc",
    "start": "DOTENV_CONFIG_PATH=../../.env node dist/index.js",
    "start:api": "DOTENV_CONFIG_PATH=../../.env APP_MODE=api node dist/index.js",
    "start:worker": "DOTENV_CONFIG_PATH=../../.env APP_MODE=worker node dist/index.js",
    "lint": "eslint src --ext .ts",
    "test": "vitest"
  },
  "dependencies": {
    "express": "^4.18.2",
    "@prisma/client": "^5.1.0",
    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "express-rate-limit": "^6.10.0",
    "redis": "^4.6.0",
    "bullmq": "^5.12.0",
    "ioredis": "^5.4.1",
    "axios": "^1.4.0",
    "zod": "^3.22.0",
    "@anthropic-ai/sdk": "^0.16.0",
    "openai": "^4.20.0",
    "socket.io": "^4.7.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@sentry/node": "^8.0.0",
    "prom-client": "^15.1.0"
  },
  "devDependencies": {
    "typescript": "^5.2.0",
    "tsx": "^4.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/bcryptjs": "^2.4.2",
    "eslint": "^8.52.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "vitest": "^1.0.0"
  }
}
