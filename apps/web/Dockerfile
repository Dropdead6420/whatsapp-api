# syntax=docker/dockerfile:1.7
#
# Multi-stage build for the NexaFlow web app in a npm workspaces monorepo.
# Build context: the repo root. Build with:
#   docker build -f apps/web/Dockerfile -t nexaflow-web:dev .

# -----------------------------------------------------------------------------
# deps — install workspace dependencies once
# -----------------------------------------------------------------------------
FROM node:20-alpine AS deps
WORKDIR /app

RUN apk add --no-cache libc6-compat openssl

COPY package.json package-lock.json* turbo.json ./
COPY apps/web/package.json ./apps/web/
COPY apps/api/package.json ./apps/api/
COPY apps/mobile/package.json ./apps/mobile/
COPY packages/shared/package.json ./packages/shared/
COPY packages/db/package.json ./packages/db/
COPY packages/ui/package.json ./packages/ui/

# Harden npm install against flaky networks.
RUN npm config set fetch-retries 5 \
  && npm config set fetch-retry-mintimeout 20000 \
  && npm config set fetch-retry-maxtimeout 120000 \
  && npm ci --no-audit --no-fund

# -----------------------------------------------------------------------------
# build — build shared types, then next build (produces .next/standalone)
# -----------------------------------------------------------------------------
FROM deps AS build
WORKDIR /app

ARG NEXT_PUBLIC_API_URL=http://localhost:3001
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL

COPY tsconfig*.json ./
COPY packages ./packages
COPY apps/web ./apps/web

# The web app imports @nexaflow/shared compiled output; build it first.
RUN cd packages/shared && npx tsc

# `output: 'standalone'` writes a self-contained bundle to
# apps/web/.next/standalone with its own minimal node_modules and server.js
ENV NEXT_TELEMETRY_DISABLED=1
RUN cd apps/web && npm run build

# -----------------------------------------------------------------------------
# runtime — copy only the standalone output + static + public
# -----------------------------------------------------------------------------
FROM node:20-alpine AS runtime
WORKDIR /app

ENV NODE_ENV=production
ENV PORT=3000
ENV NEXT_TELEMETRY_DISABLED=1
ENV NEXT_PUBLIC_API_URL=http://localhost:3001

RUN apk add --no-cache libc6-compat \
  && addgroup --system --gid 1001 nodejs \
  && adduser --system --uid 1001 nextjs

# Standalone output already includes minimal node_modules. The monorepo
# version is rooted at the workspace, so we copy it to /app.
COPY --from=build --chown=nextjs:nodejs /app/apps/web/.next/standalone ./
# Static assets (CSS, JS chunks) are not part of standalone.
COPY --from=build --chown=nextjs:nodejs /app/apps/web/.next/static ./apps/web/.next/static
# Public assets if present.
COPY --from=build --chown=nextjs:nodejs /app/apps/web/public ./apps/web/public

USER nextjs

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
  CMD wget --quiet --spider http://localhost:3000/ || exit 1

# server.js is generated by `next build` with output:'standalone'.
# In a monorepo, it lives under apps/web/.
CMD ["node", "apps/web/server.js"]
