{
	auto_https off
}

(nexaflow_app) {
	encode zstd gzip

	handle /api/* {
		reverse_proxy api:3001
	}

	handle /public/* {
		reverse_proxy api:3001
	}

	handle /webhooks/* {
		reverse_proxy api:3001
	}

	handle /realtime* {
		reverse_proxy api:3001
	}

	handle {
		reverse_proxy web:3000
	}
}

:80 {
	import nexaflow_app
}
