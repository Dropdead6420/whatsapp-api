# Copy this file to `.env.production` on the VPS and fill in the values.
# `bootstrap.sh` will offer to do this for you interactively.
#
# NEVER commit `.env.production`. The repo .gitignore excludes `.env*`
# so this file (with the `.example` suffix) is the only one tracked.

# ============================================================================
# DOMAINS
# ============================================================================

# Domain you'll use for the API. Point a DNS A-record at the VPS IP first;
# Caddy auto-provisions a Let's Encrypt cert on first request.
DOMAIN_API=api.medscrub.in

# Domain you'll use for the web frontend (the customer-facing site).
# Caddy serves both ${DOMAIN_WEB} and www.${DOMAIN_WEB}; the www form
# is auto-redirected to the apex.
DOMAIN_WEB=medscrub.in

# Optional override for CORS. Defaults to https://${DOMAIN_WEB} which is
# what you want for a single-VPS deploy. Set this if your web is hosted
# elsewhere (e.g. Vercel).
# WEB_URL=https://medscrub.in

# Which API Docker image tag to pull from GHCR. Defaults to the codex
# branch image. Switch to `latest` once you merge to main.
IMAGE_TAG=codex-nexaflow-v2-platform

# ============================================================================
# DATABASE + REDIS
# ============================================================================

# Postgres password — pick a strong random value. bootstrap.sh generates
# one with `openssl rand -base64 32` if you don't supply your own.
POSTGRES_PASSWORD=replace-me-with-a-strong-password

# ============================================================================
# AUTH + ENCRYPTION
# ============================================================================

# 32-byte base64 random. Generate: openssl rand -base64 32
JWT_SECRET=replace-me

# 32-byte base64 random. Used to envelope-encrypt tenant WABA tokens.
# DO NOT LOSE THIS VALUE — losing it makes every tenant's token unusable.
TENANT_TOKEN_ENCRYPTION_KEY=replace-me

# ============================================================================
# META / WHATSAPP
# ============================================================================

# From developers.facebook.com → your app
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret

# Pick any random string; Meta uses it to verify webhook ownership
WHATSAPP_WEBHOOK_TOKEN=your_random_webhook_token

# Optional during initial bring-up — fill once you've connected a WABA
META_PHONE_NUMBER_ID=
META_BUSINESS_ACCOUNT_ID=

# ============================================================================
# AI (optional — leave blank to disable that feature)
# ============================================================================

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ============================================================================
# OBSERVABILITY (optional)
# ============================================================================

SENTRY_DSN=
