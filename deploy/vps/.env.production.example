# Copy this file to `.env.production` on the VPS and fill in the values.
# `bootstrap.sh` will offer to do this for you interactively.
#
# NEVER commit `.env.production`. The `.gitignore` at the repo root
# already excludes `.env*` so this file (with the `.example` suffix) is
# the only one tracked.

# ============================================================================
# DOMAIN + CORS
# ============================================================================

# Your domain (without scheme). Point an A-record at the VPS IP first;
# Caddy auto-provisions a Let's Encrypt cert on first request.
DOMAIN=api.yourdomain.com

# The Vercel URL of your web frontend — CORS allows requests from this
# origin. Update later if you move the frontend.
WEB_URL=https://whatsapp-api-ruddy-alpha.vercel.app

# Which Docker image tag to pull. Defaults to the codex branch image we
# built today. Switch to `latest` once you merge to main.
IMAGE_TAG=codex-nexaflow-v2-platform

# ============================================================================
# DATABASE + REDIS
# ============================================================================

# Postgres password — pick a strong random value. bootstrap.sh can
# generate one with `openssl rand -base64 32`.
POSTGRES_PASSWORD=replace-me-with-a-strong-password

# ============================================================================
# AUTH + ENCRYPTION
# ============================================================================

# 32-byte base64 random. Generate: openssl rand -base64 32
JWT_SECRET=replace-me

# 32-byte base64 random. Used to envelope-encrypt tenant WABA tokens.
# DO NOT LOSE THIS VALUE — losing it makes every tenant's token unusable.
TENANT_TOKEN_ENCRYPTION_KEY=replace-me

# ============================================================================
# META / WHATSAPP
# ============================================================================

# From developers.facebook.com → your app
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret

# Pick any random string; Meta uses it to verify webhook ownership
WHATSAPP_WEBHOOK_TOKEN=your_random_webhook_token

# Optional during initial bring-up — fill once you've connected a WABA
META_PHONE_NUMBER_ID=
META_BUSINESS_ACCOUNT_ID=

# ============================================================================
# AI (optional — leave blank to disable that feature)
# ============================================================================

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ============================================================================
# OBSERVABILITY (optional)
# ============================================================================

SENTRY_DSN=
