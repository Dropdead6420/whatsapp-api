# NexaFlow — Caddy reverse proxy (single VPS, all-in-one)
#
# Two vhosts, both with auto-SSL via Let's Encrypt. Caddy picks the cert
# via SNI on :443. State (cert + ACME account) lives in the caddy_data
# Docker volume — losing that volume means re-issuing from scratch and
# you'll burn through Let's Encrypt rate limits.
#
# `{$DOMAIN_API}`, `{$DOMAIN_WEB}`, `{$API_UPSTREAM}`, `{$WEB_UPSTREAM}`
# come from docker-compose env (see .env.production).

# Reusable defaults — shared headers + log config — for both vhosts.
(common) {
	encode gzip zstd
	header_up X-Forwarded-Proto {scheme}
	header_up X-Forwarded-For {remote_host}
	header_up X-Real-IP {remote_host}
	header Strict-Transport-Security "max-age=31536000; includeSubDomains"
	header X-Content-Type-Options "nosniff"
	header Referrer-Policy "no-referrer-when-downgrade"
	log {
		output stdout
		format json
		level INFO
	}
}

# -----------------------------------------------------------------------------
# API — api.medscrub.in
# -----------------------------------------------------------------------------
{$DOMAIN_API} {
	import common

	# Express APIs are loaded inside <script>, never in an iframe — DENY
	# X-Frame-Options is safe + protects against clickjacking on any
	# auth-related routes that mistakenly accept GETs.
	header X-Frame-Options "DENY"

	reverse_proxy {$API_UPSTREAM} {
		# Health-check the API upstream every 10s. Caddy returns 502
		# automatically if /live stops responding.
		health_uri /live
		health_interval 10s
		health_timeout 3s

		# WebSocket support for Socket.io realtime layer.
		header_up Connection {>Connection}
		header_up Upgrade {>Upgrade}
	}
}

# -----------------------------------------------------------------------------
# Web — medscrub.in + www.medscrub.in
#
# Two-line block at the top sends www → apex (cleaner SEO, single canonical
# host). Caddy issues one cert covering both names automatically.
# -----------------------------------------------------------------------------
{$DOMAIN_WEB}, www.{$DOMAIN_WEB} {
	import common

	# Send www → apex with a 308 (preserves method, unlike 301/302).
	# Comment this block out if you'd rather keep both hosts served.
	@www host www.{$DOMAIN_WEB}
	redir @www https://{$DOMAIN_WEB}{uri} 308

	reverse_proxy {$WEB_UPSTREAM} {
		health_uri /
		health_interval 10s
		health_timeout 3s
	}
}
