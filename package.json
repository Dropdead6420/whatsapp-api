{
  "name": "nexaflow-ai",
  "version": "0.1.0",
  "description": "NexaFlow AI - Multi-tenant AI-powered WhatsApp marketing & automation platform",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
