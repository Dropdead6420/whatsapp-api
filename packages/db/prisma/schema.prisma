model Service {
  id              String        @id @default(cuid())
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name            String
  description     String?
  durationMinutes Int           // service duration in minutes (e.g. 30, 60)
  priceInPaisa    Int           // price in smallest unit (paise for INR)
  isActive        Boolean       @default(true)

  appointments    Appointment[]

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([tenantId])
  @@index([isActive])
}

enum AppointmentStatus {
  PENDING          // newly created, awaiting confirmation
  CONFIRMED        // confirmed by business
  CANCELLED        // cancelled (by customer or business)
  COMPLETED        // the appointment happened
  NO_SHOW          // customer didn't turn up
}

model Appointment {
  id                  String             @id @default(cuid())
  tenantId            String
  tenant              Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  contactId           String
  contact             Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)

  serviceId           String
  service             Service            @relation(fields: [serviceId], references: [id])

  scheduledAt         DateTime
  durationMinutes     Int                // snapshot at booking time so changing the Service later doesn't break history
  status              AppointmentStatus  @default(PENDING)
  notes               String?

  source              String             @default("PUBLIC_FORM") // PUBLIC_FORM | ADMIN | API | WHATSAPP_FLOW

  confirmationSentAt  DateTime?
  reminderSentAt      DateTime?
  // PRD §3.3.9: post-visit follow-up (review/feedback ask). Stamped
  // by the appointment worker once we've sent it, so the next scan
  // skips the row. Decoupled from `completedAt` so an operator who
  // manually back-dates a completion doesn't trigger a stale message.
  postVisitSentAt     DateTime?
  completedAt         DateTime?
  cancelledAt         DateTime?

  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([tenantId, scheduledAt])
  @@index([contactId])
  @@index([status])
  @@index([reminderSentAt])
  @@index([postVisitSentAt])
}

