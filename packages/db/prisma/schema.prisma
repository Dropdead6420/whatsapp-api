// ============================================================================
// DRIP SEQUENCES (Phase 3)
// Multi-step WhatsApp campaigns triggered by contact events. Each sequence
// has an ordered list of steps; each step is a template send + a delay
// before the next one. Enrollments track each contact's progress.
// ============================================================================

enum DripSequenceStatus {
  DRAFT // operator is still authoring; no enrollments accepted
  ACTIVE // accepting new enrollments; existing ones progress
  PAUSED // existing enrollments freeze; no new ones accepted
  ARCHIVED // hidden from UI; nothing happens
}

enum DripSequenceTrigger {
  // Slice 1 ships MANUAL only — operator/API explicitly enrolls each
  // contact. Slice 2 will add the CONTACT_CREATED + TAG_ADDED hooks.
  MANUAL
  CONTACT_CREATED
  TAG_ADDED
}

enum DripEnrollmentStatus {
  RUNNING // making progress through steps
  COMPLETED // finished the final step
  CANCELLED // operator pulled them out
  FAILED // unrecoverable error mid-sequence
}

model DripSequence {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  description String?
  status      DripSequenceStatus  @default(DRAFT)
  trigger     DripSequenceTrigger @default(MANUAL)
  // When trigger=TAG_ADDED, the tag that activates enrollment.
  triggerTag  String?

  // Ordered list of steps. Stored as JSON so we can iterate without
  // a join — each step is small and the list is short. Shape:
  //   [{ delayHours: number, templateId: string, languageCode?: string,
  //      bodyParams?: string[] }]
  // Validated at the route layer (zod).
  steps Json @default("[]")

  enrollments      DripEnrollment[]
  retentionConfigs RetentionConfig[] @relation("RetentionWinbackSequence")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([trigger, status])
}

model DripEnrollment {
  id       String @id @default(cuid())
  // Denormalized for fast tenant-scoped reads + a tenantId index on
  // the scan-worker query.
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  sequenceId String
  sequence   DripSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  contactId  String
  contact    Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)

  // Index into DripSequence.steps[] for the NEXT step to fire. When
  // the worker fires step N, it advances to N+1; if N+1 == steps.length
  // the enrollment is marked COMPLETED.
  currentStep Int                  @default(0)
  status      DripEnrollmentStatus @default(RUNNING)

  // Scan-worker wakeup driver: find RUNNING rows where nextStepAt <= now.
  nextStepAt DateTime?
  lastStepAt DateTime?

  sentCount   Int     @default(0)
  failedCount Int     @default(0)
  // Set when status moves to FAILED — what went wrong on the last send.
  lastError   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // One enrollment per contact per sequence — re-enrolling a contact
  // is an explicit operator action (cancel-then-enroll), not a silent
  // double-send.
  @@unique([sequenceId, contactId])
  @@index([tenantId, status])
  @@index([status, nextStepAt])
}

// ============================================================================
// META MARKETING API (PRD §3.3.6, Phase 4)
// One connection per tenant — stores the encrypted Facebook user access
// token + selected ad account. Slice 1 ships read-only campaign + insights
// surfacing via the Marketing API; future slices add Lead Ads sync,
// click-to-WhatsApp ad creation, and audience export.
// ============================================================================

model MetaAdsConnection {
  id       String @id @default(cuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Facebook user/system-user access token. Stored encrypted via the same
  // envelope helper used for WABA tokens (lib/tokenCrypto.ts).
  accessToken String

  // act_<numeric-id> — the active ad account. Operators can have many in
  // a single Facebook business account; this records which one we're
  // reading from. Stored without the "act_" prefix.
  adAccountId   String
  // Display label shown in the UI so operators recognize the account.
  adAccountName String?

  // Cached metadata pulled from Meta on connect. Refreshed on next sync.
  businessName String?
  currency     String? // 3-letter ISO, e.g. "INR"
  timeZoneName String? // IANA tz, e.g. "Asia/Kolkata"

  lastSyncedAt  DateTime?
  lastSyncError String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================================
// GOOGLE ADS API (PRD §3.3.7, Phase 4)
// One connection per tenant. Slice 1 stores an OAuth refresh token + the
// Google Ads customer_id (and optional manager login_customer_id) and
// surfaces read-only campaign performance via GAQL. The shared developer
// token lives in env vars (GOOGLE_ADS_DEVELOPER_TOKEN); slice 2 wires the
// proper OAuth consent flow so end-customers don't paste refresh tokens.
// ============================================================================

// Per-tenant, per-form subscription to Meta Lead Ads. A form is a Meta
// "leadgen_form" attached to one of the operator's ad sets. We poll Meta's
// /<form_id>/leads endpoint every few minutes, page through entries newer
// than `lastFetchedAt`, and create a Contact + Lead in NexaFlow.
model MetaAdsLeadForm {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  formId   String // Meta lead form id (numeric string)
  formName String?
  // Meta page that owns the form. Captured for display; not used at fetch
  // time since the form id is globally unique on Meta's side.
  pageId   String?
  pageName String?

  // Tag every imported Contact with this label so operators can segment
  // "leads from Meta" quickly. Optional — empty disables tag injection.
  importTag String?

  // Polling state.
  isActive       Boolean   @default(true)
  lastFetchedAt  DateTime?
  lastFetchError String?
  importedCount  Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, formId])
  @@index([tenantId, isActive])
  @@index([isActive, lastFetchedAt])
}

// Custom audience exports to Meta (PRD §3.3.6 retargeting slice).
// One row per (tenant, audienceId). Tracks the Meta-side custom audience
// id, the SegmentFilterSpec we built it from, and per-sync counters so
// operators can see how many contacts landed in the audience.
enum MetaAudienceStatus {
  CREATING
  READY
  REFRESHING
  FAILED
}

model MetaAdsAudience {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Meta-side custom audience id (returned on creation). Empty until the
  // first successful create call; routes refuse refresh when null.
  metaAudienceId String?

  name        String
  description String?
  // The filter spec that resolved the contact list at create / last
  // refresh time. Stored as JSON so we can re-resolve on refresh.
  // Shape matches SegmentFilterSpec from services/ai.service.ts.
  filterSpec  Json    @default("{}")

  status        MetaAudienceStatus @default(CREATING)
  lastSyncError String?

  // Counters reflect the most recent successful refresh.
  lastSyncedAt  DateTime?
  contactCount  Int       @default(0)
  // Meta returns a 24-72h match window so the audience size is eventually
  // consistent; we only know how many rows we uploaded.
  uploadedCount Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId, status])
}

model GoogleAdsConnection {
  id       String @id @default(cuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // OAuth refresh token issued by Google. Encrypted with the same envelope
  // helper used for WABA + Meta Ads.
  refreshToken String

  // 10-digit Google Ads customer id (no dashes). The account this
  // connection reads from.
  customerId      String
  // Optional Manager (MCC) customer id. When set, this is sent as the
  // login-customer-id header so Google routes the request via the manager.
  loginCustomerId String?

  // Cached metadata fetched on connect.
  customerName String?
  currency     String? // 3-letter ISO, e.g. "INR"
  timeZoneName String? // IANA tz, e.g. "Asia/Kolkata"

  lastSyncedAt  DateTime?
  lastSyncError String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================================
// AI Platform Monitor / Autonomous SaaS Operator (PRD-v2 §8, Sprint 2).
//
// The SuperAdmin's triage queue. The scheduled scan ingests signals from
// the other Sprint-2 engines (Wallet Risk, Compliance Firewall, Provider
// Router) and produces PlatformActionItem rows that the SuperAdmin sees
// on /platform-monitor. dedupeKey lets the scan upsert cleanly so the
// same condition over multiple days doesn't pile up duplicates.
// ============================================================================

enum PlatformActionStatus {
  OPEN
  ACKED
  RESOLVED
  DISMISSED
  SNOOZED
}

enum PlatformActionSeverity {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum PlatformActionCode {
  WALLET_RISK_CRITICAL
  WALLET_RISK_URGENT
  COMPLIANCE_BLOCK_SPIKE
  PROVIDER_HEALTH_DEGRADED
  WEBHOOK_FAILURE_SPIKE
  AI_USAGE_SPIKE
  CHURN_RISK
  ONBOARDING_STALLED
  DOMAIN_HEALTH_DEGRADED
  CREDIT_LINE_OVERDUE
  WABA_QUALITY_DEGRADED
}

// ============================================================================
// Customer Health Score (PRD-v2 §8, Sprint 3 foundation).
//
// Per-customer-tenant rolling health metric driven by signals from the
// other Sprint-2 engines (wallet risk + compliance) plus raw activity
// (messages, leads, conversations). Partners see their portfolio sorted
// by tier; the AI Partner Assistant (slice 2 of Sprint 3) uses the same
// rows to drive upsell + churn-prevention nudges.
//
// (tenantId, dayKey) uniqueness lets the daily scan upsert without
// bloating history.
// ============================================================================

enum CustomerHealthTier {
  THRIVING // score >= 80
  HEALTHY // score >= 60
  AT_RISK // score >= 40
  CHURNING // score < 40
}

model CustomerHealthScore {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  dayKey     String // YYYY-MM-DD (UTC)
  assessedAt DateTime @default(now())

  // Composite score 0-100. Tier derived deterministically from score
  // (no LLM in this slice; slice 2 layers an LLM narrative on top).
  score Int
  tier  CustomerHealthTier

  // Per-factor breakdown so partners + the AI assistant can see WHY a
  // tenant scored where they did. Shape:
  //   { activity: { score: 0-1, weight: 0-1, contribution: 0-100, detail: "..." },
  //     wallet: { ... },
  //     compliance: { ... },
  //     engagement: { ... },
  //     onboarding: { ... } }
  factors Json @default("{}")

  // Optional short recommendation (filled by the AI assistant in slice 2).
  recommendation String?

  createdAt DateTime @default(now())

  @@unique([tenantId, dayKey])
  @@index([tenantId, assessedAt(sort: Desc)])
  @@index([tier, assessedAt(sort: Desc)])
}

model PlatformActionItem {
  id       String                 @id @default(cuid())
  code     PlatformActionCode
  severity PlatformActionSeverity
  title    String
  body     String

  // Most items target a tenant. Cross-tenant items (e.g. global provider
  // outage) leave both null.
  targetTenantId String?
  targetTenant   Tenant? @relation(fields: [targetTenantId], references: [id], onDelete: SetNull)

  // Free-form context the UI surfaces (provider key, conversation id,
  // assessment id, etc.). Bounded to ~2KB by convention.
  context Json @default("{}")

  status           PlatformActionStatus @default(OPEN)
  resolvedAt       DateTime?
  resolvedByUserId String?
  snoozedUntil     DateTime?

  // Deterministic key the scan computes from (code, target, day) so
  // a repeated scan upserts the same row instead of creating duplicates.
  dedupeKey String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, severity, createdAt])
  @@index([targetTenantId, status])
  @@index([code, createdAt])
}

// ============================================================================
// AI Proposal Generator (PRD-v2 §6, Sprint 3 slice 4)
//
// A partner submits a one-line prospect brief (business name, industry,
// goals, scale) and Claude drafts a structured sales proposal: executive
// summary, pain points, a recommended plan with pricing, an ROI estimate,
// and an implementation timeline. The partner reviews/edits, saves, and
// later marks it SENT / ACCEPTED / DECLINED as the deal moves.
//
// `content` holds the full structured draft (see proposal.service.ts for
// the shape). Scalar `title` / `currency` / `estimatedValue` are denorm'd
// for cheap list views. `shareToken` backs the public read-only
// /p/:shareToken proposal view. Only SENT / ACCEPTED proposals are exposed.
// ============================================================================

enum ProposalStatus {
  DRAFT
  SENT
  ACCEPTED
  DECLINED
}

model Proposal {
  id String @id @default(cuid())

  // Partner tenant that owns this proposal (the seller, not the prospect).
  partnerTenantId String
  partnerTenant   Tenant @relation("PartnerProposals", fields: [partnerTenantId], references: [id], onDelete: Cascade)

  // Prospect is free-text — they are not a tenant yet.
  prospectName String
  industry     String

  // The brief the partner submitted, kept so a proposal can be regenerated.
  brief Json @default("{}")

  // Full AI-generated structured draft. Shape:
  //   { executiveSummary, painPoints[],
  //     recommendedPlan { name, priceMonthly, currency, features[] },
  //     roiEstimate { summary, metrics[] },
  //     timeline [{ phase, duration, detail }],
  //     callToAction }
  content Json @default("{}")

  // Denormalized for list views without parsing `content`.
  title          String
  currency       String @default("INR")
  estimatedValue Int? // recommended plan price, whole currency units

  status ProposalStatus @default(DRAFT)
  source String         @default("ai") // "ai" | "fallback"

  // Public read-only share page token. The API only exposes SENT / ACCEPTED
  // proposals so drafts and declined deals stay private.
  shareToken String @unique @default(cuid())

  createdByUserId String?
  sentAt          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([partnerTenantId, createdAt(sort: Desc)])
  @@index([partnerTenantId, status])
}

// ============================================================================
// AI Retention Engine (PRD-v2 §7, Sprint 4 slice 1)
//
// Customer-facing (BUSINESS tenant) contact retention scoring. A scheduled
// scan rates each contact's engagement decay from cheap Contact-row signals
// (last interaction recency, opt-out, lifecycle stage, lead score) — no
// per-contact message fan-out, so it scales to large books. Tier is derived
// deterministically; slice 2 layers LLM win-back copy + auto-enroll into a
// designated drip on top.
//
// `factors` holds the per-signal breakdown so the customer can see WHY a
// contact landed in a tier. One row per (tenant, contact, UTC day) via the
// unique key so a repeated scan upserts instead of duplicating.
// ============================================================================

enum RetentionTier {
  ACTIVE // engaged recently — no action
  COOLING // slipping — gentle nudge
  DORMANT // gone quiet — win-back candidate
  LOST // opted out or long gone
}

model ContactRetentionScore {
  id        String  @id @default(cuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  dayKey     String // YYYY-MM-DD (UTC)
  assessedAt DateTime @default(now())

  // 0-100; higher = healthier retention. Tier derived from score + recency.
  score                Int
  tier                 RetentionTier
  daysSinceInteraction Int

  factors        Json    @default("{}")
  recommendation String?

  createdAt DateTime @default(now())

  @@unique([tenantId, contactId, dayKey])
  @@index([tenantId, tier, score])
  @@index([tenantId, assessedAt(sort: Desc)])
  @@index([contactId, assessedAt(sort: Desc)])
}

// ============================================================================
// Retention autopilot config (PRD-v2 §7, Sprint 4 slice 2)
//
// One row per tenant. Implements the cross-cutting Manual / Assisted /
// Autopilot mode toggle for the win-back engine:
//   MANUAL    — engine scores + recommends only; no enrollment.
//   ASSISTED  — autopilot run surfaces candidates for operator approval.
//   AUTOPILOT — DORMANT, non-opted-out contacts are auto-enrolled into the
//               designated win-back DripSequence (capped per run).
//
// `winbackSequenceId` is SetNull on sequence delete so removing a drip never
// orphans the config; the autopilot just no-ops until a new one is chosen.
// ============================================================================

enum RetentionMode {
  MANUAL
  ASSISTED
  AUTOPILOT
}

model RetentionConfig {
  id       String @id @default(cuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  mode RetentionMode @default(MANUAL)

  // Win-back sequence DORMANT contacts get enrolled into under AUTOPILOT.
  winbackSequenceId String?
  winbackSequence   DripSequence? @relation("RetentionWinbackSequence", fields: [winbackSequenceId], references: [id], onDelete: SetNull)

  // Safety cap on enrollments per autopilot run so a first run on a large
  // dormant book can't fan out thousands of sends at once.
  maxEnrollPerRun Int @default(50)

  lastRunAt         DateTime?
  lastEnrolledCount Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([mode])
}

// ============================================================================
// White-label Domain Health (PRD-v2 §5, Sprint 5 slice 1)
//
// Append-only sample ledger written by the 6-hour DNS/SSL drift monitor.
// One row per (domain, scan-tick). The Domain row carries the current
// authoritative state (dnsStatus / sslStatus / status / lastError); samples
// are kept for trend display and to drive the consecutive-failure
// escalation rule (>=3 consecutive non-OK samples → PlatformActionItem
// DOMAIN_HEALTH_DEGRADED).
// ============================================================================

enum DomainHealthOutcome {
  OK // DNS + SSL both pass
  DNS_DRIFT // domain was LIVE; CNAME or TXT no longer resolves
  SSL_FAILED // DNS still good; SSL handshake failed
  UNREACHABLE // sample errored (network / DNS timeout)
}

model DomainHealthSample {
  id       String @id @default(cuid())
  domainId String
  domain   Domain @relation(fields: [domainId], references: [id], onDelete: Cascade)

  // Denormalized so we can group/list by partner without an extra join.
  tenantId        String
  partnerTenantId String?

  outcome   DomainHealthOutcome
  cnameOk   Boolean
  txtOk     Boolean
  sslOk     Boolean
  // Round-trip latency for the worker's slowest check, ms (debugging only).
  latencyMs Int?
  // Short, bounded error string when outcome != OK.
  error     String?

  observedAt DateTime @default(now())

  @@index([domainId, observedAt(sort: Desc)])
  @@index([tenantId, observedAt(sort: Desc)])
  @@index([partnerTenantId, outcome, observedAt(sort: Desc)])
}
