// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// MULTI-TENANT CORE
// ============================================================================

enum TenantType {
  DIRECT           // Direct business (not resold)
  WHITE_LABEL      // White-label reseller
  BUSINESS         // Business under a white-label reseller
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum DomainPortalType {
  PARTNER
  CUSTOMER
  DEMO
  API
  TRACKING
}

enum DomainDnsStatus {
  PENDING
  CNAME_FOUND
  TXT_VERIFIED
  FAILED
}

enum DomainSslStatus {
  PENDING
  ACTIVE
  FAILED
}

enum DomainStatus {
  PENDING_DNS
  DNS_FOUND
  TXT_VERIFIED
  SSL_PENDING
  SSL_ACTIVE
  LIVE
  FAILED
  SUSPENDED
}

model Tenant {
  id                       String           @id @default(cuid())
  name                     String
  type                     TenantType       @default(DIRECT)
  status                   TenantStatus     @default(ACTIVE)
  domain                   String?          @unique  // Custom domain for white-label
  parentTenantId           String?          // For businesses under resellers
  parentTenant             Tenant?          @relation("ResellChildren", fields: [parentTenantId], references: [id], onDelete: Cascade)
  resellChildren           Tenant[]         @relation("ResellChildren")

  // Branding
  logoUrl                  String?
  faviconUrl               String?
  brandColors              String?          // JSON: { primary, secondary, accent }
  customCss                String?
  customFont               String?

  // WhatsApp Configuration
  metaBusinessId           String?          // Parent Meta Business Manager id (T-004)
  wabaId                   String?          // WhatsApp Business Account ID
  wabaPhoneNumber          String?
  wabaAccessToken          String?          // Encrypted (T-094)
  wabaTokenExpiresAt       DateTime?        // expires_in stamped at OAuth exchange (T-004 follow-up)
  wabaTokenExpiryWarnedAt  DateTime?        // last time the expiry-warn worker fired
  wabaDisplayPhoneNumber   String?
  wabaQualityRating        String?
  wabaMessagingLimitTier   String?
  wabaAccountStatus        String?
  wabaLastSyncedAt         DateTime?
  wabaLastSyncError        String?

  // Business profile pulled from Meta after onboarding (T-004 follow-up).
  // Flat columns instead of a JSON blob so the inbox header and
  // analytics queries can read them without an extra parse.
  wabaBusinessName             String?
  wabaBusinessVertical         String?
  wabaBusinessAbout            String?
  wabaBusinessProfileSyncedAt  DateTime?

  // Email Configuration
  emailProvider            String?          // "resend", "sendgrid", "smtp"
  emailFromAddress         String?
  emailConfig              String?          // JSON: provider-specific config

  // Features & Limits
  messageQuotaPerMonth     Int              @default(10000)
  contactLimit             Int              @default(1000)
  agentLimit               Int              @default(5)
  aiCreditsPerMonth        Int              @default(1000)
  campaignLimit            Int              @default(100)
  featuresEnabled          String?          // JSON: { chatbot, ads, creative_studio, ... }

  // T-052 slice 4: master switch for inbound auto-reply via the
  // tenant's default AiAgent. Off by default so tenants opt in
  // explicitly; flipping this on without a default agent set is a
  // no-op (the webhook checks both).
  aiAgentAutoReply         Boolean          @default(false)

  // T-070: partner-portal nav customization. Only meaningful on
  // WHITE_LABEL tenants — controls which sidebar items are visible
  // in the partner's own portal and what label/icon they use. Shape
  // (validated at the route): { items: [{ key, label, icon, enabled }] }.
  partnerMenuConfig        Json?

  // T-041: Custom email sender (white-label). `emailFromAddress`
  // exists already (declared in the Email Configuration block above).
  // These three extend it: a display name + a verification stamp
  // (DNS check pass) + the last error message for the operator UI.
  // When emailDomainVerifiedAt is non-null AND <= 30 days old,
  // sendEmail uses the tenant's address; otherwise falls back to
  // the platform default sender. Re-verify regularly catches
  // domain misconfig (SPF deletion, DKIM key rotation, etc.).
  emailFromName            String?
  emailDomainVerifiedAt    DateTime?
  emailDomainLastError     String?

  // Inbox / support SLA — minutes from inbound to first agent reply
  slaMinutes               Int              @default(30)

  // Relations
  users                    User[]
  teams                    Team[]
  whatsappTemplates        WhatsAppTemplate[]
  contacts                 Contact[]
  campaigns                Campaign[]
  conversations            Conversation[]
  leads                    Lead[]
  chatbotFlows             ChatbotFlow[]
  subscriptions            Subscription[]
  apiKeys                  ApiKey[]
  apiRequestLogs           ApiRequestLog[]
  webhooks                 Webhook[]
  auditLogs                AuditLog[]
  aiUsage                  AiUsage[]
  knowledgeBaseEntries     KnowledgeBaseEntry[]
  aiAgents                 AiAgent[]
  invoices                 Invoice[]
  wallet                   Wallet?
  walletTransactions       WalletTransaction[] @relation("TenantWalletTransactions")
  domains                  Domain[]         @relation("TenantDomains")
  partnerDomains           Domain[]         @relation("PartnerDomains")
  passwordResetTokens      PasswordResetToken[]
  emailVerificationTokens  EmailVerificationToken[]
  cannedReplies            CannedReply[]
  conversationNotes        ConversationNote[]
  services                 Service[]
  appointments             Appointment[]
  flowRuns                 FlowRun[]
  providerRoutes           ProviderRoute[]
  branding                 Branding?
  demoTenant               DemoTenant?
  createdDemos             DemoTenant[] @relation("DemoCreatedBy")
  supportTickets           SupportTicket[]
  dripSequences            DripSequence[]
  dripEnrollments          DripEnrollment[]
  metaAdsConnection        MetaAdsConnection?
  metaAdsLeadForms         MetaAdsLeadForm[]
  metaAdsAudiences         MetaAdsAudience[]
  googleAdsConnection      GoogleAdsConnection?

  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  @@index([parentTenantId])
  @@index([status])
}

// ProviderRoute (T-005b, ADR-018) — routes WhatsApp send traffic to a
// specific BSP for a given tenant (and optionally a specific phone-number
// id). When no row matches a tenant, the factory falls back to Meta Cloud.
enum WhatsAppProviderKey {
  META
  GUPSHUP
  DIALOG_360
  TWILIO
  HAPTIK
}

model ProviderRoute {
  id            String              @id @default(cuid())
  tenantId      String
  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  providerKey   WhatsAppProviderKey

  // Optional: scope this route to a single WABA phone number. NULL means
  // "default route for this tenant".
  phoneNumberId String?

  isActive      Boolean             @default(true)

  // Provider-specific config blob — Gupshup needs an API key + app name;
  // 360dialog needs an API key; etc. JSON, envelope-encrypted on write.
  config        String?

  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  // One active default route per tenant (NULL phone) and one per
  // (tenant, phone). Deactivate before reassigning.
  @@unique([tenantId, phoneNumberId])
  @@index([tenantId])
  @@index([isActive])
}

model Domain {
  id                       String           @id @default(cuid())
  tenantId                 String
  tenant                   Tenant           @relation("TenantDomains", fields: [tenantId], references: [id], onDelete: Cascade)

  partnerTenantId          String?
  partnerTenant            Tenant?          @relation("PartnerDomains", fields: [partnerTenantId], references: [id], onDelete: SetNull)

  domain                   String           @unique
  portalType               DomainPortalType
  verificationToken        String

  cnameHost                String
  cnameValue               String
  txtHost                  String
  txtValue                 String

  dnsStatus                DomainDnsStatus  @default(PENDING)
  sslStatus                DomainSslStatus  @default(PENDING)
  status                   DomainStatus     @default(PENDING_DNS)
  isPrimary                Boolean          @default(false)

  lastCheckedAt            DateTime?
  lastError                String?

  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  @@index([tenantId])
  @@index([partnerTenantId])
  @@index([portalType])
  @@index([status])
}

// ============================================================================
// AUTHENTICATION & USERS
// ============================================================================

enum UserRole {
  SUPER_ADMIN      // Platform owner
  WHITE_LABEL_ADMIN // Reseller
  BUSINESS_ADMIN   // Business owner
  TEAM_LEAD        // Team lead
  AGENT            // Support/sales agent
}

enum UserStatus {
  ACTIVE
  PENDING_EMAIL_VERIFICATION
  SUSPENDED
  DELETED
}

model User {
  id                       String           @id @default(cuid())
  email                    String
  name                     String
  password                 String           // Hashed
  role                     UserRole
  status                   UserStatus       @default(PENDING_EMAIL_VERIFICATION)
  emailVerified            DateTime?
  twoFactorEnabled         Boolean          @default(false)
  twoFactorSecret          String?          // For TOTP

  // Multi-tenant scoping
  tenantId                 String?
  tenant                   Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Team scoping (for agents under businesses)
  assignedTeamId           String?
  assignedTeam             Team?            @relation(fields: [assignedTeamId], references: [id])

  // Relations
  conversations            Conversation[]   @relation("ConversationAgent")
  leads                    Lead[]           @relation("LeadAssignee")
  apiKeys                  ApiKey[]
  auditLogs                AuditLog[]
  walletTransactions       WalletTransaction[]
  oauthAccounts            OAuthAccount[]

  lastLoginAt              DateTime?
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  @@unique([email, tenantId])
  @@index([tenantId])
  @@index([status])
}

model OAuthAccount {
  id                       String           @id @default(cuid())
  userId                   String
  user                     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider                 String           // "google", "github", "apple"
  providerAccountId        String
  email                    String?
  name                     String?
  image                    String?
  refreshToken             String?
  accessToken              String?
  expiresAt                Int?

  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// ============================================================================
// TEAM & ORGANIZATION
// ============================================================================

model Team {
  id                       String           @id @default(cuid())
  tenantId                 String
  tenant                   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name                     String
  description              String?

  // Relations
  agents                   User[]
  conversations            Conversation[]
  leads                    Lead[]

  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  @@index([tenantId])
}

// ============================================================================
// PASSWORD RESET & EMAIL VERIFICATION
// ============================================================================

model PasswordResetToken {
  id          String   @id @default(cuid())
  userId      String
  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tokenHash   String   @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id          String   @id @default(cuid())
  userId      String
  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tokenHash   String   @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// ============================================================================
// CONTACTS & LEADS
// ============================================================================

enum LifecycleStage {
  LEAD
  PROSPECT
  CUSTOMER
  REPEAT_CUSTOMER
  VIP
  CHURNED
}

model Contact {
  id                       String           @id @default(cuid())
  tenantId                 String
  tenant                   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  phoneNumber              String
  name                     String
  email                    String?
  avatar                   String?
  tags                     String[]         // JSON array
  customFields             String?          // JSON object
  optedOut                 Boolean          @default(false)
  optedOutAt               DateTime?
  lastInteractionAt        DateTime?
  aiScore                  Float?           // AI lead score (0-1)
  lifecycleStage           LifecycleStage   @default(LEAD)

  // Relations
  conversations            Conversation[]
  leads                    Lead[]
  appointments             Appointment[]
  dripEnrollments          DripEnrollment[]

  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  @@unique([tenantId, phoneNumber])
  @@index([tenantId])
  @@index([tags])
  @@index([lifecycleStage])
}

enum LeadStatus {
  NEW
  QUALIFIED
  NEGOTIATION
  PROPOSAL_SENT
  NEGOTIATION_FAILED
  CLOSED_WON
  CLOSED_LOST
}

enum LeadFollowUpStatus {
  RECOMMENDED
  SCHEDULED
  SENT
  DISMISSED
  FAILED
}

model Lead {
  id                       String           @id @default(cuid())
  tenantId                 String
  tenant                   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contactId                String
  contact                  Contact          @relation(fields: [contactId], references: [id], onDelete: Cascade)
  
  title                    String
  description              String?
  status                   LeadStatus       @default(NEW)
  value                    Float?           // Deal value
  probability              Float?           // Probability of close (AI scored)
  
  assigneeId               String?
  assignee                 User?            @relation("LeadAssignee", fields: [assigneeId], references: [id])
  
  teamId                   String?
  team                     Team?            @relation(fields: [teamId], references: [id])

  // AI follow-up recommendation and automation state.
  followUpStatus           LeadFollowUpStatus?
  followUpPriority         String?          // "low", "medium", "high"
  followUpMessage          String?
  followUpReason           String?
  followUpDueAt            DateTime?
  followUpRecommendedAt    DateTime?
  followUpSentAt           DateTime?
  followUpLastError        String?

  closedAt                 DateTime?
  closedWonAt              DateTime?
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  @@index([tenantId])
  @@index([contactId])
  @@index([status])
  @@index([assigneeId])
  @@index([followUpStatus])
  @@index([followUpDueAt])
}

// ============================================================================
// WHATSAPP & CONVERSATIONS
// ============================================================================

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

model Conversation {
  id                       String           @id @default(cuid())
  tenantId                 String
  tenant                   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contactId                String
  contact                  Contact          @relation(fields: [contactId], references: [id], onDelete: Cascade)
  
  teamId                   String?
  team                     Team?            @relation(fields: [teamId], references: [id])
  
  agentId                  String?
  agent                    User?            @relation("ConversationAgent", fields: [agentId], references: [id])

  lastMessageAt            DateTime?
  lastInboundAt            DateTime?        // for SLA computation
  lastOutboundAt           DateTime?        // for first-response computation
  isActive                 Boolean          @default(true)

  // V2 §3.3.5: tag conversations (Urgent, Follow-up, Closed, …)
  labels                   String[]         @default([])

  // SLA tracking (V2 §6.1 "Multi-Agent WhatsApp Inbox — SLA timers")
  slaBreachedAt            DateTime?        // stamped when last-inbound exceeds slaMinutes without an agent reply
  firstResponseSeconds     Int?             // seconds from first inbound → first outbound (after the conversation existed)

  // Relations
  messages                 Message[]

  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  @@index([tenantId])
  @@index([contactId])
  @@index([teamId])
  @@index([agentId])
  @@index([isActive])
  @@index([labels])
  @@index([slaBreachedAt])
}

model Message {
  id                       String           @id @default(cuid())
  conversationId           String
  conversation             Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  campaignId               String?
  campaign                 Campaign?        @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  
  direction                MessageDirection
  status                   MessageStatus    @default(PENDING)
  
  content                  String
  mediaUrl                 String?
  mediaType                String?          // "image", "video", "audio", "document"
  
  templateId               String?
  template                 WhatsAppTemplate? @relation(fields: [templateId], references: [id])

  metaMessageId            String?          @unique
  
  aiGenerated              Boolean          @default(false)
  aiModel                  String?          // "claude-3-sonnet", etc.

  readAt                   DateTime?
  deliveredAt              DateTime?
  failureReason            String?
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  @@index([conversationId])
  @@index([campaignId])
  @@index([status])
  @@index([createdAt])
}

// ============================================================================
// WHATSAPP TEMPLATES
// ============================================================================

enum TemplateStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  FLAGGED
}

model WhatsAppTemplate {
  id                       String           @id @default(cuid())
  tenantId                 String
  tenant                   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  name                     String
  metaTemplateId           String?          // Meta's template ID
  category                 String           // "MARKETING", "OTP", "ACCOUNT_UPDATE"
  language                 String           @default("en")
  
  headerText               String?
  bodyText                 String           // Main message
  footerText               String?
  
  status                   TemplateStatus   @default(DRAFT)
  approvalReason           String?          // Why it was rejected/flagged
  
  variants                 String[]         // JSON array of variant texts
  aiScoreApprovalChance    Float?           // AI prediction of approval
  
  messageCount             Int              @default(0)
  successRate              Float?           // Success rate
  
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  // Relations
  messages                 Message[]
  campaigns                Campaign[]

  @@index([tenantId])
  @@index([status])
}

// ============================================================================
// CAMPAIGNS
// ============================================================================

enum CampaignType {
  BROADCAST
  SCHEDULED
  TRIGGERED
  A_B_TEST
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  PAUSED
  COMPLETED
  FAILED
}

model Campaign {
  id                       String           @id @default(cuid())
  tenantId                 String
  tenant                   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  name                     String
  description              String?
  type                     CampaignType
  status                   CampaignStatus   @default(DRAFT)
  
  templateId               String
  template                 WhatsAppTemplate @relation(fields: [templateId], references: [id])
  
  // Audience
  targetContacts           String           // JSON: array of contact IDs or filter criteria
  excludedContacts         String?          // JSON array
  
  // Scheduling
  scheduledFor             DateTime?
  runEvery                 String?          // Cron expression for recurring
  
  // A/B Testing
  variantId                String?          // If this is a variant
  
  // Analytics
  totalContacts            Int              @default(0)
  sentCount                Int              @default(0)
  deliveredCount           Int              @default(0)
  readCount                Int              @default(0)
  clickCount               Int              @default(0)
  conversionCount          Int              @default(0)

  // Relations
  messages                 Message[]
  
  startedAt                DateTime?
  completedAt              DateTime?
  
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
}

// ============================================================================
// CHATBOT & AUTOMATION
// ============================================================================

enum FlowNodeType {
  START
  MESSAGE
  CONDITION
  ACTION
  WEBHOOK
  DELAY
  END
}

model ChatbotFlow {
  id                       String           @id @default(cuid())
  tenantId                 String
  tenant                   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  name                     String
  description              String?
  isActive                 Boolean          @default(false)
  
  trigger                  String           // "message_received", "keyword", "button_click"
  triggerKeywords          String[]         // JSON array
  
  // Flow nodes and edges (JSON)
  nodes                    String           // JSON array of flow nodes
  edges                    String?          // JSON array of connections
  
  aiIntentEnabled          Boolean          @default(false)
  aiIntentModels           String?          // "claude-3-sonnet"
  
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  @@index([tenantId])
  @@index([isActive])
}

// ============================================================================
// WEBHOOKS & INTEGRATIONS
// ============================================================================

enum WebhookEvent {
  MESSAGE_SENT
  MESSAGE_RECEIVED
  LEAD_CREATED
  CONTACT_TAGGED
  CAMPAIGN_COMPLETED
  CONVERSATION_ASSIGNED
  APPOINTMENT_BOOKED
  TOKEN_EXPIRING
}

model Webhook {
  id                       String           @id @default(cuid())
  tenantId                 String
  tenant                   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  url                      String
  events                   WebhookEvent[]
  isActive                 Boolean          @default(true)
  secret                   String           // For HMAC signature verification
  
  retryAttempts            Int              @default(3)
  retryDelay               Int              @default(300) // seconds
  
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  @@index([tenantId])
}

model WebhookLog {
  id                       String           @id @default(cuid())
  webhookId                String
  event                    String
  payload                  String           // JSON
  statusCode               Int?
  response                 String?
  error                    String?
  attempt                  Int              @default(1)
  nextRetryAt              DateTime?
  
  createdAt                DateTime         @default(now())
}

// ============================================================================
// BILLING & SUBSCRIPTIONS
// ============================================================================

enum PlanName {
  STARTER
  GROWTH
  PRO
  ENTERPRISE
  CUSTOM
}

model Plan {
  id                       String           @id @default(cuid())
  name                     PlanName
  displayName              String
  description              String?
  priceInPaisa             Int              // Price in smallest currency unit (paise for INR)
  billingCycle             String           // "monthly", "annual"
  
  // Limits
  messageQuota             Int
  contactLimit             Int
  agentLimit               Int
  aiCreditsPerMonth        Int
  campaignLimit            Int
  
  // Features
  chatbotEnabled           Boolean          @default(false)
  adsIntegrationEnabled    Boolean          @default(false)
  creativeStudioEnabled    Boolean          @default(false)
  apiAccessEnabled         Boolean          @default(false)

  subscriptions            Subscription[]

  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum WalletStatus {
  ACTIVE
  SUSPENDED
}

enum WalletBillingMode {
  PREPAID
  POSTPAID
}

enum WalletTransactionType {
  CREDIT_ALLOCATION
  CREDIT_REVERSAL
  MANUAL_ADJUSTMENT
  TRANSFER_IN
  TRANSFER_OUT
  MESSAGE_DEBIT
  AI_DEBIT
  WORKFLOW_DEBIT
  EXPIRY
  AUTO_RECHARGE
}

enum WalletTransactionDirection {
  CREDIT
  DEBIT
}

model Wallet {
  id                       String           @id @default(cuid())
  tenantId                 String           @unique
  tenant                   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  status                   WalletStatus     @default(ACTIVE)
  billingMode              WalletBillingMode @default(PREPAID)
  balanceCredits           Int              @default(0)
  reservedCredits          Int              @default(0)
  creditLimit              Int              @default(0)
  lowBalanceThreshold      Int              @default(100)

  // T-021: auto-recharge config.
  // enabled + amount + paymentMethodToken must ALL be set for the worker
  // to attempt a charge. The token is the payment provider's opaque
  // reference (Razorpay subscription id, Stripe customer id, etc.) —
  // we never store raw card data.
  autoRechargeEnabled      Boolean          @default(false)
  autoRechargeAmountCredits Int             @default(0)
  autoRechargePaymentMethodToken String?
  autoRechargePaymentProvider String?       // "razorpay" | "stripe" | future providers
  // Stamp set after a successful auto-recharge so a hot-fire bug
  // can't drain the customer's card; the worker refuses to recharge
  // again within `AUTO_RECHARGE_COOLDOWN_HOURS` of the last attempt.
  lastAutoRechargeAt       DateTime?
  lastAutoRechargeError    String?

  transactions             WalletTransaction[] @relation("WalletTransactions")
  counterpartyTransactions WalletTransaction[] @relation("CounterpartyWallet")

  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  @@index([status])
  @@index([billingMode])
}

model WalletTransaction {
  id                       String           @id @default(cuid())
  walletId                 String
  wallet                   Wallet           @relation("WalletTransactions", fields: [walletId], references: [id], onDelete: Cascade)

  tenantId                 String
  tenant                   Tenant           @relation("TenantWalletTransactions", fields: [tenantId], references: [id], onDelete: Cascade)

  actorUserId              String?
  actorUser                User?            @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  type                     WalletTransactionType
  direction                WalletTransactionDirection
  amountCredits            Int
  balanceAfterCredits      Int
  reason                   String
  referenceType            String?
  referenceId              String?
  counterpartyWalletId     String?
  counterpartyWallet       Wallet?          @relation("CounterpartyWallet", fields: [counterpartyWalletId], references: [id], onDelete: SetNull)
  metadata                 String?

  createdAt                DateTime         @default(now())

  @@index([walletId, createdAt])
  @@index([tenantId, createdAt])
  @@index([actorUserId])
  @@index([type])
  @@index([referenceType, referenceId])

  // Idempotency: a given (wallet, referenceType, referenceId) can only have one
  // ledger entry. Postgres unique constraints treat NULL as distinct by default,
  // so admin/manual entries (no referenceId) are unaffected.
  @@unique([walletId, referenceType, referenceId])
}

