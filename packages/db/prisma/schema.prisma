  @@index([tenantId])
  @@index([type])
  @@index([status])
  @@index([billingMode])
}

// ============================================================================
// Customer self-recharge wallet (Claude FINAL §4)
//
// PaymentOrder tracks one customer-initiated checkout attempt. The
// customer hits POST /customer/wallets/recharge → service creates a
// PaymentOrder + a gateway-side order (Razorpay/Stripe order id) and
// returns the client-side init payload. When the gateway webhook
// arrives, the handler verifies the signature, looks up the
// PaymentOrder by gatewayOrderId, applies a WalletTransaction credit
// inside a transaction, and flips the order to SUCCEEDED.
//
// Idempotency lives on two surfaces:
//   - PaymentOrder.idempotencyKey (client-supplied, unique) — prevents
//     a double-click from creating two orders for the same intent.
//   - PaymentWebhookLog (gateway, eventId) unique — prevents a
//     Razorpay/Stripe webhook retry from crediting twice.
// ============================================================================

enum PaymentGateway {
  RAZORPAY
  STRIPE
  // PAYPAL, MANUAL_BANK_TRANSFER added later in their own slices.
}

enum PaymentOrderStatus {
  CREATED // Order created on our side; gateway init returned.
  PENDING // Customer is in the gateway checkout flow.
  SUCCEEDED // Webhook verified + ledger credited.
  FAILED // Gateway reported failure / signature mismatch.
  CANCELLED // Customer abandoned / explicit cancel.
  EXPIRED // Stale order swept by the reconciliation worker.
}

enum PaymentWebhookSignatureStatus {
  VALID
  INVALID
  MISSING
}

model PaymentOrder {
  id         String     @id @default(cuid())
  tenantId   String
  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  walletId   String
  wallet     Wallet     @relation(fields: [walletId], references: [id], onDelete: Cascade)
  walletType WalletType @default(WHATSAPP_USAGE)

  gateway  PaymentGateway
  /// Smallest currency unit (paise / cents). Always store integers.
  amount   Int
  currency String             @default("INR")
  status   PaymentOrderStatus @default(CREATED)

  /// Gateway's order/intent id — never null after a successful create.
  gatewayOrderId String?
  /// Client-supplied idempotency key. UNIQUE per tenant — two POSTs
  /// with the same key resolve to the same PaymentOrder row.
  idempotencyKey String

  /// When set, the WalletTransaction that booked the credit.
  ledgerTransactionId String?

  /// Gateway error message when status=FAILED.
  failureReason String?

  /// Initiator audit.
  createdByUserId String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  paidAt    DateTime?

  webhookLogs PaymentWebhookLog[]

  @@unique([tenantId, idempotencyKey])
  @@unique([gateway, gatewayOrderId])
  @@index([tenantId])
  @@index([walletId])
  @@index([status, createdAt])
}

model PaymentWebhookLog {
  id        String         @id @default(cuid())
  gateway   PaymentGateway
  /// Gateway's event id (Razorpay event id, Stripe event id).
  eventId   String
  eventType String

  signatureStatus PaymentWebhookSignatureStatus

  /// Linked PaymentOrder when the webhook payload referenced one.
  paymentOrderId String?
  paymentOrder   PaymentOrder? @relation(fields: [paymentOrderId], references: [id], onDelete: SetNull)

  /// Raw payload — useful for support / replay debugging.
  rawPayload String

  /// True when this event id was already processed before this row was
  /// written. The webhook handler always responds 200 so the gateway
  /// stops retrying, but the duplicate is recorded for auditability.
  duplicate       Boolean  @default(false)
  /// Any error encountered while processing.
  processingError String?
  processedAt     DateTime @default(now())

  @@unique([gateway, eventId])
  @@index([gateway, processedAt])
  @@index([paymentOrderId])
}

// ============================================================================
// Postpaid credit line (Claude FINAL §4 — CreditLine)
//
// One tenant can have one ACTIVE credit line at a time. Creating an
// active line flips Wallet.billingMode to POSTPAID and sets
// Wallet.creditLimit to the line's limit. Closing the line resets
// both. The wallet's negative-balance check enforces the limit at
// debit time; this model is the audit-grade source of truth (who
// approved it, when, why, due date for renewal).
//
// Why a separate model rather than just leaving the fields on
// Wallet: the PRD requires "limit, used, dueDate, status" plus an
// approver trail — none of that fits on the operational Wallet row
// without polluting it. This model is the contract; Wallet caches
// the operational state for hot-path debit checks.
// ============================================================================

enum CreditLineStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

model CreditLine {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  /// Limit in wallet credits (same unit as Wallet.balanceCredits).
  limitCredits Int
  status       CreditLineStatus @default(ACTIVE)

  /// Optional renewal date. Reaching dueDate doesn't auto-suspend;
  /// a future worker may flag overdue lines for SuperAdmin review.
  dueDate DateTime?

  /// SuperAdmin who approved the line. The approver trail is what
  /// distinguishes a CreditLine row from a plain Wallet.creditLimit
  /// number — finance / compliance needs to know who said yes.
  approvedByUserId String?

  /// Free-text justification (e.g. "Enterprise contract #1234,
  /// 30-day NET terms").
  notes String?

  openedAt    DateTime  @default(now())
  closedAt    DateTime?
  /// When the line was suspended (PII-style trail). Set on every
  /// SUSPENDED transition; cleared if the line is reactivated to
  /// ACTIVE before being CLOSED.
  suspendedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([status, dueDate])
}

// ============================================================================
// Manual bank transfer recharge (Claude FINAL §4 — RechargeRequest)
//
// Customers without card support (or paying via NEFT/IMPS/UPI to the
// platform's bank account) submit a RechargeRequest with proof. A
// SuperAdmin reviews the proof and approves — approval credits the
// wallet via the same WalletTransaction ledger as Razorpay so the
// audit trail is consistent.
// ============================================================================

enum RechargeRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model RechargeRequest {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  /// Smallest currency unit (paise / cents).
  amount     Int
  currency   String                @default("INR")
  status     RechargeRequestStatus @default(PENDING)
  walletType WalletType            @default(WHATSAPP_USAGE)

  /// URL to the bank-transfer proof (screenshot / PDF receipt).
  /// We don't host the file ourselves; the customer uploads to their
  /// own object store or the partner's portal.
  proofUrl     String?
  /// Customer-supplied reference (UTR / transaction id) so SuperAdmin
  /// can reconcile with the bank statement.
  reference    String?
  /// Customer-supplied note (which bank account, payer name etc.).
  customerNote String?

  /// SuperAdmin's note on approve / reject.
  adminNotes String?

  createdByUserId  String?
  approvedByUserId String?
  approvedAt       DateTime?
  rejectedAt       DateTime?

  /// When approved, the WalletTransaction that booked the credit.
  ledgerTransactionId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([status, createdAt])
}

// ============================================================================
// AI Wallet Risk Engine (PRD-v2 §8, Sprint 2)
//
// One row per assessment. The scheduled worker runs every few hours and
// writes a row per tenant; uniqueness on (tenantId, dayKey) so re-runs
// inside the same UTC day upsert instead of bloating history. Reads:
//   - Latest row (riskTier + recommendation) drives the wallet banner UI.
//   - Time series (assessedAt desc) drives the SuperAdmin trend chart.
// ============================================================================

enum WalletRiskTier {
  OK
  WATCH
  URGENT
  CRITICAL
}

enum WalletRiskAction {
  NONE
  RECHARGE
  ENABLE_AUTO_RECHARGE
  THROTTLE_CAMPAIGNS
  SWITCH_TO_POSTPAID
  UPGRADE_PLAN
}

model WalletRiskAssessment {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  walletId String
  wallet   Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  // UTC date key (YYYY-MM-DD) — gives the (tenantId, dayKey) uniqueness
  // that keeps repeat scans idempotent within a day.
  dayKey     String
  assessedAt DateTime @default(now())

  // Snapshot of inputs at assessment time so a re-read isn't dependent on
  // the live wallet (which may have moved since).
  balanceCredits      Int
  lowBalanceThreshold Int

  // 14-day rolling stats. Float because the average isn't an integer when
  // burn happens in small increments per send.
  dailyBurnAvg     Float
  dailyBurnP90     Float
  daysToLowBalance Float?
  daysToZero       Float?

  riskTier                 WalletRiskTier
  recommendedActionCode    WalletRiskAction @default(NONE)
  recommendedAmountCredits Int?
  reasoning                String?

  // True when the LLM was consulted. Tiers below WATCH skip the LLM call
  // to keep AI spend bounded; the row still exists with deterministic
  // math, just without a narrative.
  llmUsed Boolean @default(false)

  createdAt DateTime @default(now())

  @@unique([tenantId, dayKey])
  @@index([tenantId, assessedAt(sort: Desc)])
  @@index([riskTier, assessedAt(sort: Desc)])
}

model WalletTransaction {
  id       String @id @default(cuid())
  walletId String
  wallet   Wallet @relation("WalletTransactions", fields: [walletId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   Tenant @relation("TenantWalletTransactions", fields: [tenantId], references: [id], onDelete: Cascade)

  actorUserId String?
  actorUser   User?   @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  type                 WalletTransactionType
  direction            WalletTransactionDirection
  amountCredits        Int
  balanceAfterCredits  Int
  reason               String
  referenceType        String?
  referenceId          String?
  counterpartyWalletId String?
  counterpartyWallet   Wallet?                    @relation("CounterpartyWallet", fields: [counterpartyWalletId], references: [id], onDelete: SetNull)
  metadata             String?

  createdAt DateTime @default(now())

  // Idempotency: a given (wallet, referenceType, referenceId) can only have one
  // ledger entry. Postgres unique constraints treat NULL as distinct by default,
  // so admin/manual entries (no referenceId) are unaffected.
  @@unique([walletId, referenceType, referenceId])
  @@index([walletId, createdAt])
  @@index([tenantId, createdAt])
  @@index([actorUserId])
  @@index([type])
  @@index([referenceType, referenceId])
}

model Subscription {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  planId String
  plan   Plan   @relation(fields: [planId], references: [id])

  status SubscriptionStatus @default(ACTIVE)

  currentPeriodStart DateTime
