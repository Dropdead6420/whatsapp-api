enum WalletTransactionType {
  CREDIT_ALLOCATION
  CREDIT_REVERSAL
  MANUAL_ADJUSTMENT
  TRANSFER_IN
  TRANSFER_OUT
  MESSAGE_DEBIT
  AI_DEBIT
  WORKFLOW_DEBIT
  EXPIRY
  AUTO_RECHARGE
}

