// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// MULTI-TENANT CORE
// ============================================================================

enum TenantType {
  DIRECT // Direct business (not resold)
  WHITE_LABEL // White-label reseller
  BUSINESS // Business under a white-label reseller
}

// Partner billing/provider models (Claude Final Corrected Billing §4).
// Set on a WHITE_LABEL partner tenant at creation.
enum PartnerModel {
  RESELLER // Model A — resells NexaFlow on NexaFlow/approved provider; NexaFlow owns rates
  BRING_YOUR_OWN_META // Model B — partner brings own Meta/BSP credentials
  HYBRID // Model C — per-customer choice of NexaFlow vs partner route
}

// Who owns the WhatsApp provider credentials for a given customer
// (Claude Final §4: "Provider ownership must be recorded").
enum ProviderOwnership {
  NEXAFLOW_OWNED
  PARTNER_OWNED
  CUSTOMER_OWNED
}

// Where a customer's usage is charged from (Claude Final §4: "Credit
// source must be recorded").
enum CreditSource {
  CUSTOMER_WALLET
  PARTNER_WALLET
  PARTNER_CREDIT_LINE
  CUSTOMER_CREDIT_LINE
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum DomainPortalType {
  PARTNER
  CUSTOMER
  DEMO
  API
  TRACKING
}

enum DomainDnsStatus {
  PENDING
  CNAME_FOUND
  TXT_VERIFIED
  FAILED
}

enum DomainSslStatus {
  PENDING
  ACTIVE
  FAILED
}

enum DomainStatus {
  PENDING_DNS
  DNS_FOUND
  TXT_VERIFIED
  SSL_PENDING
  SSL_ACTIVE
  LIVE
  FAILED
  SUSPENDED
}

model Tenant {
  id             String       @id @default(cuid())
  name           String
  type           TenantType   @default(DIRECT)
  status         TenantStatus @default(ACTIVE)
  domain         String?      @unique // Custom domain for white-label
  parentTenantId String? // For businesses under resellers
  parentTenant   Tenant?      @relation("ResellChildren", fields: [parentTenantId], references: [id], onDelete: Cascade)
  resellChildren Tenant[]     @relation("ResellChildren")

  // Partner model (Claude Final Corrected Billing §4). partnerModel +
  // partnerMarginEnabled are set on the WHITE_LABEL partner tenant.
  // providerOwnership + creditSource are set per customer (BUSINESS)
  // tenant at provisioning — a HYBRID partner can mix routes/credit
  // sources across its customers.
  partnerModel         PartnerModel?
  partnerMarginEnabled Boolean           @default(false)
  providerOwnership    ProviderOwnership @default(NEXAFLOW_OWNED)
  creditSource         CreditSource      @default(CUSTOMER_WALLET)

  // Branding
  logoUrl     String?
  faviconUrl  String?
  brandColors String? // JSON: { primary, secondary, accent }
  customCss   String?
  customFont  String?

  // WhatsApp Configuration
  metaBusinessId          String? // Parent Meta Business Manager id (T-004)
  wabaId                  String? // WhatsApp Business Account ID
  wabaPhoneNumber         String?
  wabaAccessToken         String? // Encrypted (T-094)
  wabaTokenExpiresAt      DateTime? // expires_in stamped at OAuth exchange (T-004 follow-up)
  wabaTokenExpiryWarnedAt DateTime? // last time the expiry-warn worker fired
  wabaDisplayPhoneNumber  String?
  wabaQualityRating       String?
  wabaMessagingLimitTier  String?
  wabaAccountStatus       String?
  wabaLastSyncedAt        DateTime?
  wabaLastSyncError       String?

  // Business profile pulled from Meta after onboarding (T-004 follow-up).
  // Flat columns instead of a JSON blob so the inbox header and
  // analytics queries can read them without an extra parse.
  wabaBusinessName            String?
  wabaBusinessVertical        String?
  wabaBusinessAbout           String?
  wabaBusinessProfileSyncedAt DateTime?

  // Email Configuration
  emailProvider    String? // "resend", "sendgrid", "smtp"
  emailFromAddress String?
  emailConfig      String? // JSON: provider-specific config

  // Features & Limits
  messageQuotaPerMonth Int     @default(10000)
  contactLimit         Int     @default(1000)
  agentLimit           Int     @default(5)
  aiCreditsPerMonth    Int     @default(1000)
  campaignLimit        Int     @default(100)
  featuresEnabled      String? // JSON: { chatbot, ads, creative_studio, ... }

  // T-052 slice 4: master switch for inbound auto-reply via the
  // tenant's default AiAgent. Off by default so tenants opt in
  // explicitly; flipping this on without a default agent set is a
  // no-op (the webhook checks both).
  aiAgentAutoReply Boolean @default(false)

  // T-070: partner-portal nav customization. Only meaningful on
  // WHITE_LABEL tenants — controls which sidebar items are visible
  // in the partner's own portal and what label/icon they use. Shape
  // (validated at the route): { items: [{ key, label, icon, enabled }] }.
  partnerMenuConfig Json?

  // T-080: per-tenant Compliance Firewall mode. Shape:
  // { default: "ASSISTED" | "MANUAL" | "AUTOPILOT",
  //   CAMPAIGN?, DRIP_STEP?, TEMPLATE?, REPLY? }
  // Missing scopes fall back to `default`; missing `default` is ASSISTED.
  complianceMode Json?

  complianceChecks ComplianceCheck[]

  // T-041: Custom email sender (white-label). `emailFromAddress`
  // exists already (declared in the Email Configuration block above).
  // These three extend it: a display name + a verification stamp
  // (DNS check pass) + the last error message for the operator UI.
  // When emailDomainVerifiedAt is non-null AND <= 30 days old,
  // sendEmail uses the tenant's address; otherwise falls back to
  // the platform default sender. Re-verify regularly catches
  // domain misconfig (SPF deletion, DKIM key rotation, etc.).
  emailFromName         String?
  emailDomainVerifiedAt DateTime?
  emailDomainLastError  String?

  // Inbox / support SLA — minutes from inbound to first agent reply
  slaMinutes Int @default(30)

  // Relations
  users                    User[]
  teams                    Team[]
  whatsappTemplates        WhatsAppTemplate[]
  contacts                 Contact[]
  campaigns                Campaign[]
  conversations            Conversation[]
  leads                    Lead[]
  chatbotFlows             ChatbotFlow[]
  subscriptions            Subscription[]
  apiKeys                  ApiKey[]
  apiRequestLogs           ApiRequestLog[]
  webhooks                 Webhook[]
  auditLogs                AuditLog[]
  aiUsage                  AiUsage[]
  knowledgeBaseEntries     KnowledgeBaseEntry[]
  aiAgents                 AiAgent[]
  invoices                 Invoice[]
  wallets                  Wallet[]
  walletTransactions       WalletTransaction[]       @relation("TenantWalletTransactions")
  domains                  Domain[]                  @relation("TenantDomains")
  partnerDomains           Domain[]                  @relation("PartnerDomains")
  passwordResetTokens      PasswordResetToken[]
  emailVerificationTokens  EmailVerificationToken[]
  cannedReplies            CannedReply[]
  conversationNotes        ConversationNote[]
  followUpTasks            FollowUpTask[]
  paymentOrders            PaymentOrder[]
  rechargeRequests         RechargeRequest[]
  creditLines              CreditLine[]
  usageEvents              UsageEvent[]
  numberMigrations         NumberMigration[]
  services                 Service[]
  appointments             Appointment[]
  flowRuns                 FlowRun[]
  providerRoutes           ProviderRoute[]
  branding                 Branding?
  demoTenant               DemoTenant?
  createdDemos             DemoTenant[]              @relation("DemoCreatedBy")
  supportTickets           SupportTicket[]
  dripSequences            DripSequence[]
  dripEnrollments          DripEnrollment[]
  metaAdsConnection        MetaAdsConnection?
  metaAdsLeadForms         MetaAdsLeadForm[]
  metaAdsAudiences         MetaAdsAudience[]
  googleAdsConnection      GoogleAdsConnection?
  walletRiskAssessments    WalletRiskAssessment[]
  providerHealthSamples    ProviderHealthSample[]
  platformActionItems      PlatformActionItem[]
  customerHealthScores     CustomerHealthScore[]
  partnerProposals         Proposal[]                @relation("PartnerProposals")
  contactRetentionScores   ContactRetentionScore[]
  retentionConfig          RetentionConfig?
  analyticsReportSchedules AnalyticsReportSchedule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentTenantId])
  @@index([status])
}

// ProviderRoute (T-005b, ADR-018) — routes WhatsApp send traffic to a
// specific BSP for a given tenant (and optionally a specific phone-number
// id). When no row matches a tenant, the factory falls back to Meta Cloud.
enum WhatsAppProviderKey {
  META
  GUPSHUP
  DIALOG_360
  TWILIO
  HAPTIK
}

enum WhatsAppUsageCategory {
  MARKETING
  UTILITY
  AUTHENTICATION
  SERVICE
}

enum UsageEventKind {
  WHATSAPP_MESSAGE
  AI_CALL
}

enum UsageEventStatus {
  QUOTED
  AUTHORIZED
  DEBITED
  BLOCKED
  FAILED
}

// ============================================================================
// Provider Router telemetry (PRD-v2 §8, Sprint 2 slice 1).
//
// Append-only health-sample ledger written by the WhatsApp send pipeline
// on every outbound send. Aggregations over a rolling window drive the
// SuperAdmin per-tenant stats view today; the smart-selection layer that
// uses these stats to choose between Meta-Direct / Gupshup / 360dialog /
// Twilio / Haptik per send is slice 2.
// ============================================================================

enum WhatsAppSendKind {
  TEXT
  TEMPLATE
}

model ProviderHealthSample {
  id            String              @id @default(cuid())
  tenantId      String
  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  providerKey   WhatsAppProviderKey
  // Which WABA phone-number routed this send (when known). Null for
  // tenant-default-route sends.
  phoneNumberId String?
  kind          WhatsAppSendKind

  success    Boolean
  // Provider HTTP status when known. Adapters that don't expose one
  // (e.g. SDK callbacks) leave this null.
  statusCode Int?
  // Provider-shaped error code on failure (e.g. Meta's "131056"). Free-form
  // because each provider has its own taxonomy; the SuperAdmin view groups
  // by code so operators can spot patterns.
  errorCode  String?
  // Round-trip latency in ms. Null only when timing wasn't captured (very
  // rare — the wrapper always sets it).
  latencyMs  Int?

  createdAt DateTime @default(now())

  @@index([tenantId, providerKey, createdAt])
  @@index([providerKey, createdAt])
}

model ProviderRoute {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  providerKey WhatsAppProviderKey

  // Optional: scope this route to a single WABA phone number. NULL means
  // "default route for this tenant".
  phoneNumberId String?

  isActive Boolean @default(true)

  // Provider-specific config blob — Gupshup needs an API key + app name;
  // 360dialog needs an API key; etc. JSON, envelope-encrypted on write.
  config String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // One active default route per tenant (NULL phone) and one per
  // (tenant, phone). Deactivate before reassigning.
  @@unique([tenantId, phoneNumberId])
  @@index([tenantId])
  @@index([isActive])
}

// ============================================================================
// Corrected billing rate engine (NexaFlow_Codex_Final_Corrected_Billing)
//
// WhatsAppRateTable stores the real provider/category/country cost surface.
// PartnerRateRule overlays partner markup without mutating the base table.
// UsageEvent records every quoted/debited unit so wallet billing is traceable
// and idempotent.
//
// Amounts ending in `Micros` use 1/1,000,000 of the row currency. This keeps
// fractional WhatsApp rates exact without floating-point money math. The API
// converts final totals to integer wallet credits at the boundary.
// ============================================================================

model WhatsAppRateTable {
  id          String                @id @default(cuid())
  countryCode String
  category    WhatsAppUsageCategory
  providerKey WhatsAppProviderKey

  currency           String @default("INR")
  baseCostMicros     BigInt
  providerCostMicros BigInt @default(0)
  taxBps             Int    @default(0)
  gatewayFeeBps      Int    @default(0)

  isActive      Boolean   @default(true)
  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  notes         String?

  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([countryCode, category, providerKey, isActive, effectiveFrom])
  @@index([providerKey, isActive])
}

model PartnerRateRule {
  id               String  @id @default(cuid())
  partnerTenantId  String
  customerTenantId String?

  countryCode String?
  category    WhatsAppUsageCategory?
  providerKey WhatsAppProviderKey?

  markupBps         Int    @default(0)
  fixedMarkupMicros BigInt @default(0)
  priority          Int    @default(100)

  isActive      Boolean   @default(true)
  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  notes         String?

  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([partnerTenantId, isActive, priority])
  @@index([customerTenantId, isActive])
  @@index([countryCode, category, providerKey])
}

model UsageEvent {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  partnerTenantId String?

  kind   UsageEventKind
  status UsageEventStatus @default(QUOTED)

  idempotencyKey String
  providerKey    WhatsAppProviderKey?
  countryCode    String?
  category       WhatsAppUsageCategory?
  units          Int                    @default(1)
  source         String?
  referenceType  String?
  referenceId    String?
  contentHash    String?

  rateTableId String?

  currency            String @default("INR")
  baseCostMicros      BigInt @default(0)
  providerCostMicros  BigInt @default(0)
  partnerMarkupBps    Int    @default(0)
  partnerMarkupMicros BigInt @default(0)
  taxBps              Int    @default(0)
  gatewayFeeBps       Int    @default(0)
  subtotalMicros      BigInt @default(0)
  taxMicros           BigInt @default(0)
  gatewayFeeMicros    BigInt @default(0)
  totalCostMicros     BigInt @default(0)
  walletCurrency      String @default("INR")
  currencyRateMicros  BigInt @default(1000000)
  walletCostMicros    BigInt @default(0)
  walletDebitCredits  Int    @default(0)

  aiFeature String?
  metadata  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, kind, createdAt])
  @@index([status, createdAt])
  @@index([referenceType, referenceId])
  @@index([partnerTenantId, createdAt])
}

// Platform FX rates (Claude Corrected Billing §3 — multi-currency).
// 1 unit of baseCurrency = rateMicros / 1_000_000 units of quoteCurrency.
// The rate engine resolves UsageEvent.currencyRateMicros from the active
// row for (rate.currency → wallet.currency). Effective-dated like the
// WhatsApp rate table; the newest active row wins for a given pair.
model CurrencyRate {
  id            String @id @default(cuid())
  baseCurrency  String // ISO-4217, the priced-in currency (e.g. USD)
  quoteCurrency String // ISO-4217, the wallet/settlement currency (e.g. INR)
  rateMicros    BigInt // quote units per 1 base unit, ×1_000_000

  source String? // "manual", "ecb", "openexchangerates", …
  notes  String?

  isActive      Boolean   @default(true)
  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?

  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([baseCurrency, quoteCurrency, isActive, effectiveFrom], map: "CurrencyRate_pair_active_from_idx")
}

model Domain {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation("TenantDomains", fields: [tenantId], references: [id], onDelete: Cascade)

  partnerTenantId String?
  partnerTenant   Tenant? @relation("PartnerDomains", fields: [partnerTenantId], references: [id], onDelete: SetNull)

  domain            String           @unique
  portalType        DomainPortalType
  verificationToken String

  cnameHost  String
  cnameValue String
  txtHost    String
  txtValue   String

  dnsStatus DomainDnsStatus @default(PENDING)
  sslStatus DomainSslStatus @default(PENDING)
  status    DomainStatus    @default(PENDING_DNS)
  isPrimary Boolean         @default(false)

  lastCheckedAt DateTime?
  lastError     String?

  healthSamples DomainHealthSample[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([partnerTenantId])
  @@index([portalType])
  @@index([status])
}

// ============================================================================
// AUTHENTICATION & USERS
// ============================================================================

enum UserRole {
  SUPER_ADMIN // Platform owner
  WHITE_LABEL_ADMIN // Reseller
  BUSINESS_ADMIN // Business owner
  TEAM_LEAD // Team lead
  AGENT // Support/sales agent
}

enum UserStatus {
  ACTIVE
  PENDING_EMAIL_VERIFICATION
  SUSPENDED
  DELETED
}

model User {
  id               String     @id @default(cuid())
  email            String
  name             String
  password         String // Hashed
  role             UserRole
  status           UserStatus @default(PENDING_EMAIL_VERIFICATION)
  emailVerified    DateTime?
  twoFactorEnabled Boolean    @default(false)
  twoFactorSecret  String? // For TOTP

  // Multi-tenant scoping
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Team scoping (for agents under businesses)
  assignedTeamId String?
  assignedTeam   Team?   @relation(fields: [assignedTeamId], references: [id])

  // Relations
  conversations      Conversation[]      @relation("ConversationAgent")
  leads              Lead[]              @relation("LeadAssignee")
  apiKeys            ApiKey[]
  auditLogs          AuditLog[]
  walletTransactions WalletTransaction[]
  oauthAccounts      OAuthAccount[]
  followUpsAssigned  FollowUpTask[]      @relation("FollowUpAssignee")
  followUpsCreated   FollowUpTask[]      @relation("FollowUpCreator")

  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([email, tenantId])
  @@index([tenantId])
  @@index([status])
}

model OAuthAccount {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          String // "google", "github", "apple"
  providerAccountId String
  email             String?
  name              String?
  image             String?
  refreshToken      String?
  accessToken       String?
  expiresAt         Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// ============================================================================
// TEAM & ORGANIZATION
// ============================================================================

model Team {
  id          String  @id @default(cuid())
  tenantId    String
  tenant      Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?

  // Relations
  agents        User[]
  conversations Conversation[]
  leads         Lead[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

// ============================================================================
// PASSWORD RESET & EMAIL VERIFICATION
// ============================================================================

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tenantId  String?
  tenant    Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tenantId  String?
  tenant    Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// ============================================================================
// CONTACTS & LEADS
// ============================================================================

enum LifecycleStage {
  LEAD
  PROSPECT
  CUSTOMER
  REPEAT_CUSTOMER
  VIP
  CHURNED
}

model Contact {
  id                String         @id @default(cuid())
  tenantId          String
  tenant            Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  phoneNumber       String
  name              String
  email             String?
  avatar            String?
  tags              String[] // JSON array
  customFields      String? // JSON object
  optedOut          Boolean        @default(false)
  optedOutAt        DateTime?
  lastInteractionAt DateTime?
  aiScore           Float? // AI lead score (0-1)
  lifecycleStage    LifecycleStage @default(LEAD)

  // Relations
  conversations   Conversation[]
  leads           Lead[]
  appointments    Appointment[]
  dripEnrollments DripEnrollment[]
  retentionScores ContactRetentionScore[]
  followUpTasks   FollowUpTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, phoneNumber])
  @@index([tenantId])
  @@index([tags])
  @@index([lifecycleStage])
}

enum LeadStatus {
  NEW
  QUALIFIED
  NEGOTIATION
  PROPOSAL_SENT
  NEGOTIATION_FAILED
  CLOSED_WON
  CLOSED_LOST
}

enum LeadFollowUpStatus {
  RECOMMENDED
  SCHEDULED
  SENT
  DISMISSED
  FAILED
}

model Lead {
  id        String  @id @default(cuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  title       String
  description String?
  status      LeadStatus @default(NEW)
  value       Float? // Deal value
  probability Float? // Probability of close (AI scored)

  assigneeId String?
  assignee   User?   @relation("LeadAssignee", fields: [assigneeId], references: [id])

  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id])

  // AI follow-up recommendation and automation state.
  followUpStatus        LeadFollowUpStatus?
  followUpPriority      String? // "low", "medium", "high"
  followUpMessage       String?
  followUpReason        String?
  followUpDueAt         DateTime?
  followUpRecommendedAt DateTime?
  followUpSentAt        DateTime?
  followUpLastError     String?

  closedAt    DateTime?
  closedWonAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tenantId])
  @@index([contactId])
  @@index([status])
  @@index([assigneeId])
  @@index([followUpStatus])
  @@index([followUpDueAt])
}

// ============================================================================
// FOLLOW-UP TASKS (PRD-v2 §7 — Agent inbox)
// ============================================================================
//
// Lightweight reminder system. An agent reading a conversation can drop a
// task on their own (or a teammate's) queue with a due date. Separate
// from Lead.followUp* (which is the AI-recommended lead-driven nudge);
// these are operator-authored.

enum FollowUpTaskStatus {
  PENDING
  DONE
  CANCELLED
}

model FollowUpTask {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  title  String             @db.VarChar(280)
  notes  String?
  status FollowUpTaskStatus @default(PENDING)
  dueAt  DateTime

  // The agent the task is for. Can be reassigned.
  assigneeId String
  assignee   User   @relation("FollowUpAssignee", fields: [assigneeId], references: [id])

  // Who created the task (audit). Goes null if the creator user is
  // later deleted so the task itself survives.
  createdById String?
  createdBy   User?   @relation("FollowUpCreator", fields: [createdById], references: [id], onDelete: SetNull)

  // Optional links — a task can be tenant-only with no contact context.
  contactId      String?
  contact        Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  completedAt DateTime?
  cancelledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([assigneeId, status, dueAt])
  @@index([contactId])
  @@index([conversationId])
}

// ============================================================================
// WhatsApp number migration (Claude FINAL §10)
//
// Moving an existing WhatsApp number onto our platform is a sequenced
// Meta flow: confirm eligibility → request + verify an OTP Meta texts
// to the number → release it from the old BSP → re-subscribe our
// webhook on the new WABA → re-sync templates. Each step can fail or
// be cancelled, so the migration is a small state machine with a row
// per attempt (history is auditable; one ACTIVE attempt per tenant is
// enforced at the service layer).
//
// This slice ships the model + the pure state machine; the Meta API
// calls + routes + status UI land in subsequent slices.
// ============================================================================

enum NumberMigrationStatus {
  PENDING_ELIGIBILITY // created; checking with Meta whether the number can migrate
  ELIGIBLE // Meta confirmed it can migrate
  NOT_ELIGIBLE // terminal — Meta refused (number on another BSP lock, etc.)
  OTP_REQUESTED // Meta texted/called an OTP to the number
  OTP_VERIFIED // OTP confirmed; ready to cut over
  MIGRATING // releasing old provider + webhook re-subscribe + template sync
  COMPLETED // terminal success — number live on our WABA
  FAILED // terminal failure (failureReason set)
  CANCELLED // operator aborted before completion
}

model NumberMigration {
  id       String @id @default(cuid())
  tenantId String
