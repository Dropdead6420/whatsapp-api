enum SupportTicketStatus {
  NEW
  OPEN
  PENDING_CUSTOMER
  RESOLVED
  CLOSED
}

enum SupportTicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum SupportTicketSenderType {
  CUSTOMER
  PARTNER
  SYSTEM
}

model SupportTicket {
  id       String @id @default(cuid())
  // Customer (child) tenant that raised the ticket.
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  subject  String
  status   SupportTicketStatus   @default(NEW)
  priority SupportTicketPriority @default(MEDIUM)

  // Creator (User.id, no FK relation — kept loose so deleting a user
